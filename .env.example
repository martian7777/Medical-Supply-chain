# Copy to .env.local and fill in. NEVER commit .env.local.
# Values below are the defaults printed by `pnpm db:start` (local Supabase).

# --- Public (safe to ship to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only. Bypasses RLS. Must never appear in a client bundle. ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Direct Postgres connection (Drizzle migrations, batch generation, spike) ---
# Local:  postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Vercel: use the Supavisor TRANSACTION pooler URI (port 6543), not the direct 5432 URI.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Salt for hashing IPs/user-agents in verification_scans. Rotate = lose scan correlation.
SCAN_HASH_SALT=dev-only-change-me
